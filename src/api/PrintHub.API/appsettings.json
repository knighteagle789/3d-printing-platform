{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=printhub_dev;Username=printhub_user;Password=<set-in-appsettings.Development.json>;Include Error Detail=true"
  },
  "WebAppUrl": "http://localhost:3000",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/printhub-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "NocoMakeLab.API",
    "Audience": "NocoMakeLab.Web",
    "ExpirationHours": "1"
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "3d-models",
    "MaxFileSizeMB": 100
  },
  "Intake": {
    "Enabled": true,
    "Extractor": {
      "Provider": "Mock",
      "AzureVision": {
        "Endpoint": "",
        "Key": ""
      }
    },
    "Confidence": {
      "HighThreshold": 0.85,
      "LowThreshold": 0.55
    },
    "Queue": {
      "Name": "material-intake-extraction",
      "PollIntervalSeconds": 5,
      "MaxRetries": 3,
      "VisibilityTimeoutSeconds": 30
    },
    "ImageProcessing": {
      "ConvertHeicToJpeg": true,
      "MaxUploadBytes": 52428800,
      "MaxLongEdgePixels": 2048,
      "JpegQuality": 85
    }
  },
  "FileAnalysis": {
    "EnableAutoAnalysis": true,
    "MaxTriangleCount": 1000000,
    "DefaultPrintSpeedMmPerSec": 50,
    "SupportedFormats": [
      "stl",
      "obj",
      "3mf"
    ]
  },
  "Email": {
    "ResendApiKey": "",
    "FromEmail": "noreply@noco3dworks.com",
    "FromName": "NoCo Make Lab",
    "AdminEmail": "admin@noco3dworks.com"
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": ""
  },
  "Pricing": {
    "HandlingFeePerModel": 4.00,
    "MachineRatePerHour": 3.50,
    "QualityMultipliers": {
      "Draft": 0.8,
      "Standard": 1.0,
      "High": 1.3
    }
  }
}
